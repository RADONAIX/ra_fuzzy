{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "RADONAIX — System (node_exporter)",
  "uid": "radonaix-system",
  "tags": ["radonaix"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "server",
        "type": "query",
        "label": "Server",
        "description": "Driven by the UI Server buttons via ?var-server=...; hidden here to avoid a duplicate control.",
        "hide": 2,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(up{job=\"node\"}, server)", "refId": "server" },
        "definition": "label_values(up{job=\"node\"}, server)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU busy %",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",server=~\"$server\"}[5m])) * 100)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Memory used %",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(100 * (1 - (node_memory_MemAvailable_bytes{server=~\"$server\"} / node_memory_MemTotal_bytes{server=~\"$server\"}))) or (100 * (node_memory_active_bytes{server=~\"$server\"} + node_memory_wired_bytes{server=~\"$server\"} + node_memory_compressed_bytes{server=~\"$server\"}) / node_memory_total_bytes{server=~\"$server\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Root disk used %",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",server=~\"$server\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",server=~\"$server\"}))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - node_boot_time_seconds{server=~\"$server\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU usage by mode",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\",server=~\"$server\"}[5m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{server=~\"$server\"} or node_memory_total_bytes{server=~\"$server\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(node_memory_MemTotal_bytes{server=~\"$server\"} - node_memory_MemAvailable_bytes{server=~\"$server\"}) or (node_memory_active_bytes{server=~\"$server\"} + node_memory_wired_bytes{server=~\"$server\"} + node_memory_compressed_bytes{server=~\"$server\"})",
          "legendFormat": "used",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network traffic",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo\",server=~\"$server\"}[5m]))",
          "legendFormat": "rx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo\",server=~\"$server\"}[5m]))",
          "legendFormat": "tx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_disk_read_bytes_total{server=~\"$server\"}[5m]))",
          "legendFormat": "read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_disk_written_bytes_total{server=~\"$server\"}[5m]))",
          "legendFormat": "write",
          "refId": "B"
        }
      ]
    },
    {
      "id": 19,
      "type": "row",
      "title": "Postgres connections",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Max connections",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(pg_settings_max_connections{server=~\"$server\"})", "refId": "A" }
      ]
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Total connections",
      "description": "Total client connections to Postgres (idle + active), excluding the monitoring exporter. With connection pooling most are idle; this is the real 'how loaded is the DB' number. (state=active alone is near-zero — see the over-time chart.)",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 150 }, { "color": "red", "value": 240 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "radonaix_pg_connections_total{server=~\"$server\"}", "refId": "A" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Postgres connections by database",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_database_numbackends{datname!=\"\",server=~\"$server\"}", "legendFormat": "{{datname}}", "refId": "A" }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Postgres connections over time",
      "description": "Total vs. active (running a query) vs. idle, against max_connections, for the selected server.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "max_connections" },
            "properties": [ { "id": "custom.lineStyle", "value": { "dash": [8, 6], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "custom.fillOpacity", "value": 0 } ] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "radonaix_pg_connections_total{server=~\"$server\"}", "legendFormat": "total", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "radonaix_pg_connections_active{server=~\"$server\"}", "legendFormat": "active", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "radonaix_pg_connections_idle{server=~\"$server\"}", "legendFormat": "idle", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(pg_settings_max_connections{server=~\"$server\"})", "legendFormat": "max_connections", "refId": "D" }
      ]
    }
  ]
}
